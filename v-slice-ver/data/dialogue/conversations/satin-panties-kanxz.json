      "text": [
        "Parece que sí..."
      ]
    },
    {
      "speaker": "mom-1",
      "speakerAnimation": "talk-mom",
      "box": "kanxz",
      "boxAnimation": "left",
      "speed": 0.05,
      "text": [
        "Bueno, bueno..."
      ]
    },
    {
      "speaker": "mom-1",
      "speakerAnimation": "talk-mom",
      "box": "kanxz",
      "boxAnimation": "left",
      "speed": 0.05,
      "text": [
        "¿Aquí es donde estuviste escondiéndote, huh?"
      ]
    },
    {
      "speaker": "kanxz-1",
      "speakerAnimation": "poker-face-kanxz",
      "box": "kanxz",
      "boxAnimation": "right",
      "speed": 0.05,
      "text": [
